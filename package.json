{
  "name": "forge-app",
  "version": "0.1.0",
  "description": "Personal AI-powered desktop IDE — Electron + MCP + Monaco + xterm.js",
  "main": "dist-electron/main/index.js",
  "author": "abd-ellah hioun <abd-ellah.hioun.pro@laplateforme.io>",
  "license": "MIT",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "electron-winstaller"
    ],
    "ignoredBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "node-pty"
    ]
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.43.0",
    "lucide-react": "^0.511.0",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^14.0.0",
    "ws": "^8.18.2",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.1.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.3",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.4.1",
    "drizzle-kit": "^0.31.0",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.26.0",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "io.laplateforme.forge",
    "productName": "Forge",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      ".env"
    ]
  }
}
