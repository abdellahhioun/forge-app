{
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@renderer/*": ["./renderer/src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["renderer/src/**/*", "shared/**/*"]
}
